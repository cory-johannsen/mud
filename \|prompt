93:// characterFlow runs the character selection/creation UI after login.
94:// It exits by calling gameBridge with the selected or newly created character.
95://
96:// Precondition: acct.ID must be > 0; conn must be open.
97:// Postcondition: Calls gameBridge on success; returns non-nil error on fatal failure.
98:func (h *AuthHandler) characterFlow(ctx context.Context, conn *telnet.Conn, acct postgres.Account) error {
99:	for {
100:		chars, err := h.characters.ListByAccount(ctx, acct.ID)
101:		if err != nil {
102:			return fmt.Errorf("listing characters: %w", err)
103:		}
104:
105:		if len(chars) == 0 {
106:			_ = conn.WriteLine(telnet.Colorize(telnet.BrightYellow,
107:				"\r\nYou have no characters. Let's create one."))
108:			c, err := h.characterCreationFlow(ctx, conn, acct.ID)
109:			if err != nil {
110:				return err
111:			}
112:			if c == nil {
113:				continue // user cancelled — loop again
114:			}
115:			if err := h.ensureGender(ctx, conn, c); err != nil {
116:				return err
117:			}
118:			if err := h.ensureSkills(ctx, conn, c); err != nil {
119:				return err
120:			}
121:			if err := h.ensureFeats(ctx, conn, c); err != nil {
122:				return err
123:			}
124:			if err := h.ensureClassFeatures(ctx, conn, c); err != nil {
125:				return err
126:			}
127:			if err := h.gameBridge(ctx, conn, acct, c); err != nil {
128:				if errors.Is(err, ErrSwitchCharacter) {
129:					continue
130:				}
131:				if IsAlreadyLoggedIn(err) {
132:					_ = conn.WriteLine(telnet.Colorize(telnet.Red, "That character is already logged in."))
133:					continue
134:				}
135:				return err
136:			}
137:			return nil
138:		}
139:
140:		// Show character list
141:		_ = conn.WriteLine(telnet.Colorize(telnet.BrightWhite, "\r\nYour characters:"))
142:		for i, c := range chars {
143:			_ = conn.WriteLine(fmt.Sprintf("  %s%d%s. %s",
144:				telnet.Green, i+1, telnet.Reset,
145:				FormatCharacterSummary(c, h.regionDisplayName(c.Region))))
146:		}
147:		_ = conn.WriteLine(fmt.Sprintf("  %s%d%s. Create a new character",
148:			telnet.Green, len(chars)+1, telnet.Reset))
149:		_ = conn.WriteLine(fmt.Sprintf("  %squit%s. Disconnect",
150:			telnet.Green, telnet.Reset))
151:		_ = conn.WriteLine(telnet.Colorize(telnet.Yellow, "  Type 'delete N' to permanently delete character N."))
152:
153:		_ = conn.WritePrompt(telnet.Colorf(telnet.BrightWhite, "Select [1-%d]: ", len(chars)+1))
154:		line, err := conn.ReadLine()
155:		if err != nil {
156:			return fmt.Errorf("reading character selection: %w", err)
157:		}
158:		line = strings.TrimSpace(line)
159:
160:		if strings.ToLower(line) == "quit" || strings.ToLower(line) == "exit" {
161:			_ = conn.WriteLine(telnet.Colorize(telnet.Cyan, "Goodbye."))
162:			return nil
163:		}
164:
165:		// Handle "delete N" command.
166:		if lower := strings.ToLower(line); strings.HasPrefix(lower, "delete ") {
167:			parts := strings.Fields(line)
168:			if len(parts) == 2 {
169:				var delIdx int
170:				if _, scanErr := fmt.Sscan(parts[1], &delIdx); scanErr == nil && delIdx >= 1 && delIdx <= len(chars) {
171:					target := chars[delIdx-1]
172:					_ = conn.WritePrompt(telnet.Colorf(telnet.Red,
173:						"Delete %q? This cannot be undone. Type 'yes' to confirm: ", target.Name))
174:					confirm, readErr := conn.ReadLine()
175:					if readErr != nil {
176:						return fmt.Errorf("reading delete confirmation: %w", readErr)
177:					}
178:					if strings.TrimSpace(strings.ToLower(confirm)) == "yes" {
179:						if delErr := h.characters.DeleteByAccountAndName(ctx, acct.ID, target.Name); delErr != nil {
180:							_ = conn.WriteLine(telnet.Colorize(telnet.Red, "Failed to delete character."))
181:						} else {
182:							_ = conn.WriteLine(telnet.Colorf(telnet.Cyan, "%q has been deleted.", target.Name))
183:						}
184:					} else {
185:						_ = conn.WriteLine(telnet.Colorize(telnet.Yellow, "Delete cancelled."))
186:					}
187:				} else {
188:					_ = conn.WriteLine(telnet.Colorize(telnet.Red, "Invalid selection for delete."))
189:				}
190:			} else {
191:				_ = conn.WriteLine(telnet.Colorize(telnet.Red, "Usage: delete N"))
192:			}
193:			continue
194:		}
195:
196:		choice := 0
197:		if _, err := fmt.Sscanf(line, "%d", &choice); err != nil || choice < 1 || choice > len(chars)+1 {
198:			_ = conn.WriteLine(telnet.Colorize(telnet.Red, "Invalid selection."))
199:			continue
200:		}
201:
202:		if choice == len(chars)+1 {
203:			c, err := h.characterCreationFlow(ctx, conn, acct.ID)
204:			if err != nil {
205:				return err
206:			}
207:			if c != nil {
208:				if err := h.ensureGender(ctx, conn, c); err != nil {
209:					return err
210:				}
211:				if err := h.ensureSkills(ctx, conn, c); err != nil {
212:					return err
213:				}
214:				if err := h.ensureFeats(ctx, conn, c); err != nil {
215:					return err
216:				}
217:				if err := h.ensureClassFeatures(ctx, conn, c); err != nil {
218:					return err
219:				}
220:				if err := h.gameBridge(ctx, conn, acct, c); err != nil {
221:					if errors.Is(err, ErrSwitchCharacter) {
222:						continue
223:					}
224:					if IsAlreadyLoggedIn(err) {
225:						_ = conn.WriteLine(telnet.Colorize(telnet.Red, "That character is already logged in."))
226:						continue
227:					}
228:					return err
229:				}
230:				return nil
231:			}
232:			continue
233:		}
234:
235:		selected := chars[choice-1]
236:		if err := h.ensureGender(ctx, conn, selected); err != nil {
237:			return err
238:		}
239:		if err := h.ensureSkills(ctx, conn, selected); err != nil {
240:			return err
241:		}
242:		if err := h.ensureFeats(ctx, conn, selected); err != nil {
243:			return err
244:		}
245:		if err := h.ensureClassFeatures(ctx, conn, selected); err != nil {
246:			return err
247:		}
248:		if err := h.gameBridge(ctx, conn, acct, selected); err != nil {
249:			if errors.Is(err, ErrSwitchCharacter) {
250:				continue
251:			}
252:			if IsAlreadyLoggedIn(err) {
253:				_ = conn.WriteLine(telnet.Colorize(telnet.Red, "That character is already logged in."))
254:				continue
255:			}
256:			return err
257:		}
258:		return nil
259:	}
260:}
