29:// RandomizeRemaining selects a region, team, and job for character creation,
30:// using fixed values where provided and random selection otherwise.
31://
32:// Precondition: regions, teams, and allJobs must each be non-empty; returns error if any is empty or no compatible jobs exist.
33:// Postcondition: returned job.Team is "" or equals returned team.ID; err is non-nil if no compatible jobs exist.
34:func RandomizeRemaining(
35:	regions []*ruleset.Region, fixedRegion *ruleset.Region,
36:	teams []*ruleset.Team, fixedTeam *ruleset.Team,
37:	allJobs []*ruleset.Job,
38:) (region *ruleset.Region, team *ruleset.Team, job *ruleset.Job, err error) {
39:	if len(regions) == 0 {
40:		err = fmt.Errorf("RandomizeRemaining: regions must be non-empty")
41:		return
42:	}
43:	if len(teams) == 0 {
44:		err = fmt.Errorf("RandomizeRemaining: teams must be non-empty")
45:		return
46:	}
47:	if len(allJobs) == 0 {
48:		err = fmt.Errorf("RandomizeRemaining: allJobs must be non-empty")
49:		return
50:	}
51:	if fixedRegion != nil {
52:		region = fixedRegion
53:	} else {
54:		region = regions[rand.Intn(len(regions))]
55:	}
56:
57:	if fixedTeam != nil {
58:		team = fixedTeam
59:	} else {
60:		team = teams[rand.Intn(len(teams))]
61:	}
62:
63:	var compatible []*ruleset.Job
64:	for _, j := range allJobs {
65:		if j.Team == "" || j.Team == team.ID {
66:			compatible = append(compatible, j)
67:		}
68:	}
69:	if len(compatible) == 0 {
70:		err = fmt.Errorf("RandomizeRemaining: no jobs compatible with team %q", team.ID)
71:		return
72:	}
73:	job = compatible[rand.Intn(len(compatible))]
74:	return region, team, job, nil
75:}
